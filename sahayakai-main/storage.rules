rules_version = '2';

// Firebase Storage rules for SahayakAI.
//
// QA #13 (2026-06-02) voice-message upload fix: previously no storage.rules
// existed in the repo, which means uploads to `voice-messages/{uid}/…` from
// the messaging voice-recorder were rejected with `storage/unauthorized` and
// the message never sent. This file adds an explicit ownership rule for the
// voice-message path; reference it from `firebase.json` and deploy with
// `firebase deploy --only storage`.
service firebase.storage {
    match /b/{bucket}/o {
        // ── Voice messages (1-to-1 / group DM chat) ─────────────────────────
        // H8 (BUG_AUDIT_2026-07-02): reads were auth-wide, so ANY signed-in
        // user could pull any teacher's private voice DMs off guessable
        // voice-messages/{uid}/{timestamp} paths. Client reads are now DENIED
        // entirely — playback is proxy-only via POST /api/media/sign, which
        // verifies conversation membership server-side and mints a 10-minute
        // V4 signed URL. Upload rules unchanged (owner-only, audio, 5 MB).
        //
        // New path written by src/components/messages/voice-recorder.tsx:
        //   voice-messages/{uid}/{conversationId}/{timestamp}.{webm|m4a}
        match /voice-messages/{userId}/{conversationId}/{fileName} {
            allow read: if false;  // proxy-only — see /api/media/sign
            allow write: if request.auth != null
                         && request.auth.uid == userId
                         && request.resource.size < 5 * 1024 * 1024
                         && request.resource.contentType.matches('audio/.*');
            allow delete: if request.auth != null && request.auth.uid == userId;
        }

        // Legacy pre-H8 layout: voice-messages/{uid}/{timestamp}.{webm|m4a}.
        // No new uploads land here (recorder now writes the nested path).
        // Existing messages keep playing via the token-bearing download URL
        // already stored on the message doc (tokens are rule-independent);
        // SDK/path reads are closed like the nested path above.
        match /voice-messages/{userId}/{fileName} {
            allow read: if false;  // proxy-only — see /api/media/sign
            allow write: if false; // new uploads use the conversation-scoped path
            allow delete: if request.auth != null && request.auth.uid == userId;
        }

        // ── Community chat voice notes ──────────────────────────────────────
        // Path written by src/components/messages/voice-recorder.tsx when
        // used from community-chat.tsx (no conversationId prop):
        //   community-voice/{uid}/{timestamp}.{webm|m4a}
        // Auth-wide read is INTENTIONAL here (H8 reviewed): these clips are
        // posted to the public community chat — shared-to-community by
        // intent, unlike private DM audio above.
        match /community-voice/{userId}/{fileName} {
            allow read: if request.auth != null;
            allow write: if request.auth != null
                         && request.auth.uid == userId
                         && request.resource.size < 5 * 1024 * 1024
                         && request.resource.contentType.matches('audio/.*');
            allow delete: if request.auth != null && request.auth.uid == userId;
        }

        // ── User uploads (resource sharing, lesson media) ────────────────────
        // Path written by src/components/image-uploader.tsx:
        //   users/{userId}/uploads/{uuid}_{filename}
        // Auth-wide read is INTENTIONAL (H8 reviewed): these images are
        // uploaded to be shared into community resources/lessons — shared by
        // intent, unlike private DM audio.
        match /users/{userId}/uploads/{fileName=**} {
            allow read: if request.auth != null;
            // Images only (matches the uploader's jpeg/png/webp accept list).
            // Without a contentType gate a user could upload .html / SVG-with-
            // <script> and get a trusted-domain URL → stored XSS / phishing.
            allow write: if request.auth != null
                         && request.auth.uid == userId
                         && request.resource.size < 10 * 1024 * 1024
                         && request.resource.contentType.matches('image/(jpeg|png|webp)');
            allow delete: if request.auth != null && request.auth.uid == userId;
        }

        // ── Profile photos / avatars ─────────────────────────────────────────
        // Path written by src/app/settings/page.tsx (custom avatar upload):
        //   profile-photos/{userId}/{uuid}.{ext}
        // Authenticated-read so the photo URL works in shared resources and
        // the community directory. 5 MB cap (avatars are tiny) + image-only.
        match /profile-photos/{userId}/{fileName=**} {
            allow read: if request.auth != null;
            allow write: if request.auth != null
                         && request.auth.uid == userId
                         && request.resource.size < 5 * 1024 * 1024
                         // Raster images only — exclude image/svg+xml (SVG can carry
                         // <script>, and avatars render on trusted app pages).
                         && request.resource.contentType.matches('image/(jpeg|png|webp|gif|heic|heif)');
            allow delete: if request.auth != null && request.auth.uid == userId;
        }

        // ── Legacy fallback for any older /uploads/{uid}/ path ───────────────
        // Kept in case any cached page on an older build still posts here.
        // Safe to delete once we confirm no client traffic hits it.
        match /uploads/{userId}/{fileName=**} {
            allow read: if request.auth != null;
            allow write: if request.auth != null
                         && request.auth.uid == userId
                         && request.resource.size < 10 * 1024 * 1024
                         && request.resource.contentType.matches('image/(jpeg|png|webp)');
            allow delete: if request.auth != null && request.auth.uid == userId;
        }

        // Default-deny everything else.
        match /{allPaths=**} {
            allow read, write: if false;
        }
    }
}
