rules_version = '2';

// Firebase Storage rules for SahayakAI.
//
// QA #13 (2026-06-02) voice-message upload fix: previously no storage.rules
// existed in the repo, which means uploads to `voice-messages/{uid}/…` from
// the messaging voice-recorder were rejected with `storage/unauthorized` and
// the message never sent. This file adds an explicit ownership rule for the
// voice-message path; reference it from `firebase.json` and deploy with
// `firebase deploy --only storage`.
service firebase.storage {
    match /b/{bucket}/o {
        // ── Voice messages (1-to-1 chat) ────────────────────────────────────
        // Path written by src/components/messages/voice-recorder.tsx:
        //   voice-messages/{uid}/{timestamp}.{webm|m4a}
        // Only the signed-in owner can upload; any signed-in user can
        // download (recipients need to play back). 5 MB cap is generous for
        // a typical 1–2 minute opus/m4a clip and keeps abuse bounded.
        match /voice-messages/{userId}/{fileName} {
            allow read: if request.auth != null;
            allow write: if request.auth != null
                         && request.auth.uid == userId
                         && request.resource.size < 5 * 1024 * 1024
                         && request.resource.contentType.matches('audio/.*');
            allow delete: if request.auth != null && request.auth.uid == userId;
        }

        // ── Image uploads (resource sharing, avatars, lesson media) ─────────
        // Mirrors the voice-messages owner-write / authenticated-read pattern
        // for any image uploaded under a user-scoped prefix. Add additional
        // explicit matches above this one for stricter feature-specific
        // limits as those features go to GA.
        match /uploads/{userId}/{fileName=**} {
            allow read: if request.auth != null;
            allow write: if request.auth != null
                         && request.auth.uid == userId
                         && request.resource.size < 10 * 1024 * 1024;
            allow delete: if request.auth != null && request.auth.uid == userId;
        }

        // Default-deny everything else.
        match /{allPaths=**} {
            allow read, write: if false;
        }
    }
}
