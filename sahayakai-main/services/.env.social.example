# SahayakAI Social Automation — env template
# Copy to .env.social and fill in. NEVER commit .env.social.

# Postgres (shared by n8n + Twenty)
PG_USER=sahayak
PG_PASSWORD=replace-with-strong-password
PG_DB=sahayak_social

# Redis (shared session store + queue)
REDIS_PASSWORD=replace-with-strong-password

# n8n
N8N_HOST=localhost
N8N_PROTOCOL=http
N8N_WEBHOOK_URL=http://localhost:5678/
N8N_ENCRYPTION_KEY=replace-with-32-plus-char-random-string

# Twenty CRM
TWENTY_SERVER_URL=http://localhost:3001
TWENTY_APP_SECRET=replace-with-32-plus-char-random-string

# Shared key between Next.js (sahayakai-main) and the workers.
# Workers reject any request missing X-Internal-Key: <this>.
INTERNAL_API_KEY=replace-with-32-plus-char-random-string

# Meta WhatsApp Cloud API (brand channel)
META_WA_PHONE_NUMBER_ID=
META_WA_BUSINESS_ACCOUNT_ID=
META_WA_ACCESS_TOKEN=
META_WA_VERIFY_TOKEN=replace-with-random-string

# Meta Instagram Graph API (brand channel — once @sahayakai created)
META_IG_USER_ID=
META_IG_ACCESS_TOKEN=
