rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    // --- Feedback (signed-in users only) ---
    match /feedbacks/{document} {
      allow create: if isSignedIn();
    }

    // --- Users ---
    // Each user can only read/write their own document
    match /users/{userId} {
      allow read, update: if request.auth.uid == userId;
      allow create: if request.auth.uid == userId;
    }

    // --- Content ---
    // User-generated content (lesson plans, quizzes, etc.) stored in top-level collection
    match /content/{documentId} {
      allow read, update, delete: if request.auth.uid == resource.data.userId;
      allow create: if request.auth.uid == request.resource.data.userId;
    }

    // --- Community Library ---
    // Public read; writes only via trusted backend (Server SDK / Admin SDK)
    match /community/{communityContentId} {
      allow read: if true;
      allow write: if false;
    }

    // --- Direct Messages & Group Conversations ---

    match /conversations/{convId} {
      // Only participants can read or update the conversation doc (e.g. unread counts)
      allow read, update: if isSignedIn()
        && request.auth.uid in resource.data.participantIds;

      // Only authenticated users can create; they must include themselves as a participant
      allow create: if isSignedIn()
        && request.auth.uid in request.resource.data.participantIds;

      match /messages/{msgId} {
        // Only participants can read messages
        allow read: if isSignedIn()
          && request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.participantIds;

        // Only a participant can create a message, and only as themselves
        allow create: if isSignedIn()
          && request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.participantIds
          && request.resource.data.senderId == request.auth.uid
          && request.resource.data.text.size() <= 1000;

        // readBy updates (mark as read) allowed for participants only
        allow update: if isSignedIn()
          && request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.participantIds;

        allow delete: if false;
      }
    }

    // --- Community Chat (broadcast — all signed-in users) ---
    match /community_chat/{messageId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.authorId == request.auth.uid
        && (request.resource.data.text.size() <= 500 || request.resource.data.audioUrl is string);
      allow update, delete: if false;
    }

    // --- Connection Requests (pending invitations) ---
    // Created by sender; readable/deletable by either party; never mutated (update: false)
    match /connection_requests/{reqId} {
      // Sender must be signed in, must be themselves, and cannot self-connect
      allow create: if isSignedIn()
        && request.resource.data.fromUid == request.auth.uid
        && request.resource.data.fromUid != request.resource.data.toUid;

      // Both sender and recipient can read (to check pending state)
      allow read: if isSignedIn()
        && (request.auth.uid == resource.data.fromUid
            || request.auth.uid == resource.data.toUid);

      // Either party can delete (sender withdraws / recipient declines)
      allow delete: if isSignedIn()
        && (request.auth.uid == resource.data.fromUid
            || request.auth.uid == resource.data.toUid);

      // Requests are immutable — accept/decline = delete + write to /connections
      allow update: if false;
    }

    // --- Connections (accepted, symmetric) ---
    // Written only by Admin SDK (server action); clients can read + self-disconnect
    match /connections/{connId} {
      // Any signed-in user can query connections (needed for directory lookups)
      allow read: if isSignedIn();

      // Only Admin SDK server action can create (accept request)
      allow create: if false;

      // Either participant can disconnect (delete the document)
      allow delete: if isSignedIn()
        && request.auth.uid in resource.data.uids;

      allow update: if false;
    }
  }
}
