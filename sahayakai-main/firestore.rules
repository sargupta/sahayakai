rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Check if caller is an admin of the given org
    function isOrgAdmin(orgId) {
      return isSignedIn()
        && get(/databases/$(database)/documents/organizations/$(orgId)/members/$(request.auth.uid)).data.role == 'admin';
    }

    // Check if caller is a member of the given group (via members subcollection)
    function isGroupMember(groupId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/groups/$(groupId)/members/$(request.auth.uid));
    }

    // =============================================
    // EXISTING COLLECTIONS
    // =============================================

    // --- Feedback (signed-in users only) ---
    match /feedbacks/{document} {
      allow create: if isSignedIn();
    }

    // --- Users ---
    // Each user can only read/write their own document
    match /users/{userId} {
      allow read, update: if isOwner(userId);
      allow create: if isOwner(userId);
    }

    // --- Content ---
    // User-generated content (lesson plans, quizzes, etc.) stored in top-level collection
    match /content/{documentId} {
      allow read, update, delete: if request.auth.uid == resource.data.userId;
      allow create: if request.auth.uid == request.resource.data.userId;
    }

    // --- Community Library ---
    // Public read; writes only via trusted backend (Server SDK / Admin SDK)
    match /community/{communityContentId} {
      allow read: if true;
      allow write: if false;
    }

    // --- Direct Messages & Group Conversations ---

    match /conversations/{convId} {
      allow read, update: if isSignedIn()
        && request.auth.uid in resource.data.participantIds;

      allow create: if isSignedIn()
        && request.auth.uid in request.resource.data.participantIds;

      match /messages/{msgId} {
        allow read: if isSignedIn()
          && request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.participantIds;

        allow create: if isSignedIn()
          && request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.participantIds
          && request.resource.data.senderId == request.auth.uid
          && request.resource.data.text.size() <= 1000;

        allow update: if isSignedIn()
          && request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.participantIds;

        allow delete: if false;
      }
    }

    // --- Community Chat (broadcast — all signed-in users) ---
    match /community_chat/{messageId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.authorId == request.auth.uid
        && (request.resource.data.text.size() <= 500 || request.resource.data.audioUrl is string);
      allow update, delete: if false;
    }

    // --- Connection Requests ---
    match /connection_requests/{reqId} {
      allow create: if isSignedIn()
        && request.resource.data.fromUid == request.auth.uid
        && request.resource.data.fromUid != request.resource.data.toUid;

      allow read: if isSignedIn()
        && (request.auth.uid == resource.data.fromUid
            || request.auth.uid == resource.data.toUid);

      allow delete: if isSignedIn()
        && (request.auth.uid == resource.data.fromUid
            || request.auth.uid == resource.data.toUid);

      allow update: if false;
    }

    // --- Connections (accepted, symmetric) ---
    match /connections/{connId} {
      allow read: if isSignedIn();
      allow create: if false;
      allow delete: if isSignedIn()
        && request.auth.uid in resource.data.uids;
      allow update: if false;
    }

    // =============================================
    // COMMUNITY: GROUPS, POSTS, LIBRARY
    // =============================================
    // All writes flow through server actions (Admin SDK, bypassing these rules).
    // Client reads are gated to authenticated members of the relevant group.

    // --- Groups (metadata) ---
    // Anyone signed in can read group metadata (name, description, member count) —
    // needed for the Discover Groups surface. Only members can read posts/chat
    // inside the group (see nested matches below). All writes go through server.
    match /groups/{groupId} {
      allow read: if isSignedIn();
      allow write: if false;

      // --- Group Posts ---
      // Read: members only. Write: server-only (createGroupPostAction uses Admin SDK).
      match /posts/{postId} {
        allow read: if isGroupMember(groupId);
        allow write: if false;

        // Likes subcollection: owner-only read/write
        match /likes/{likerId} {
          allow read, write: if isOwner(likerId) && isGroupMember(groupId);
        }
      }

      // --- Group Members ---
      // Read: any member can see the membership list. Write: server-only
      // (joinGroupAction / leaveGroupAction use Admin SDK).
      match /members/{memberId} {
        allow read: if isGroupMember(groupId);
        allow write: if false;
      }

      // --- Group Chat (real-time messages) ---
      // Read + create: members only. Update/delete: server-only.
      match /chat/{messageId} {
        allow read: if isGroupMember(groupId);
        allow create: if isGroupMember(groupId)
          && request.resource.data.authorId == request.auth.uid
          && (request.resource.data.text.size() <= 500 || request.resource.data.audioUrl is string);
        allow update, delete: if false;
      }
    }

    // --- Public Community Posts (top-level `posts` collection) ---
    // The community feed reads here. Authenticated users can read; writes flow
    // through createPostAction (Admin SDK).
    match /posts/{postId} {
      allow read: if isSignedIn();
      allow write: if false;

      match /likes/{likerId} {
        allow read, write: if isOwner(likerId);
      }
    }

    // --- Community Library Resources ---
    // Public for signed-in users (community discovery). Writes via
    // publishContentToLibraryAction / scheduled jobs (Admin SDK).
    match /library_resources/{resourceId} {
      allow read: if isSignedIn();
      allow write: if false;

      // Likes / Saves subcollections — owner-only
      match /likes/{likerId} {
        allow read, write: if isOwner(likerId);
      }
      match /saves/{saverId} {
        allow read, write: if isOwner(saverId);
      }
    }

    // =============================================
    // BILLING & ORGANIZATION COLLECTIONS
    // =============================================

    // --- Credit Ledger ---
    // Stores balance, plan, cycle dates per user.
    // Read: owner only. Write: Admin SDK only (server-side billing logic).
    match /credit_ledger/{userId} {
      allow read: if isOwner(userId);
      allow write: if false;
    }

    // --- Organizations ---
    // School/chain info, Razorpay IDs, seat counts.
    // Read: org admins only (via get() on members subcollection).
    // Write: Admin SDK only.
    match /organizations/{orgId} {
      allow read: if isOrgAdmin(orgId);
      allow write: if false;

      // --- Organization Members ---
      // Read: org admins can list all members; teachers can read their own doc.
      // Write: Admin SDK only (invite/remove handled server-side).
      match /members/{memberId} {
        allow read: if isOwner(memberId) || isOrgAdmin(orgId);
        allow write: if false;
      }
    }

    // --- Webhook Events ---
    // Razorpay idempotency tracking. Completely backend-only.
    match /webhook_events/{eventId} {
      allow read, write: if false;
    }

    // --- Config: Plans ---
    // Feature limits per plan. Readable by any authenticated user.
    // Written only via Admin SDK or Firebase console.
    match /config/plans {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // --- Usage Counters ---
    // Per-user monthly/daily usage counters for subscription gating.
    // Read: owner only. Write: Admin SDK only (incremented server-side).
    match /usageCounters/{userId} {
      allow read: if isOwner(userId);
      allow write: if false;
    }

    // --- Subscriptions ---
    // Razorpay subscription tracking. Read: owner only. Write: Admin SDK only.
    match /subscriptions/{subId} {
      allow read: if isSignedIn()
        && resource.data.userId == request.auth.uid;
      allow write: if false;
    }

    // --- System Config ---
    // Feature flags, rollout config. Readable by authenticated users.
    match /system_config/{docId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // =============================================
    // DEFAULT DENY
    // =============================================
    // Any collection not matched above is denied by default.
    // This explicit rule documents the intent — Firestore denies
    // unmatched paths anyway, but this makes audits clearer.
  }
}
