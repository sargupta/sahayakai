# SahayakAI — environment configuration template
# Copy to `.env.local` for local dev. Production values live in Cloud Run
# env vars + Secret Manager. The variables below are READ AT PROCESS
# START — bumping a number means you must redeploy (or restart `next
# dev`) for the new value to take effect.

# ─── LLM dispatcher timeouts (NCERT demo hot-fix, 2026-05-19) ────────
# Each of the five at-risk LLM flows now reads its budget from an env
# var, falling back to a safe production default. Bump these BEFORE
# running a flaky demo — increase by 5-10s when you see "timed out
# after Xms" structured-log lines in Cloud Run.

# Rubric generator (default 30s). Observed p50 was 17.3s. Same knob
# governs the sidecar HTTP client TIMEOUT_MS (default 25s) — set this
# to the larger of the two budgets you want.
RUBRIC_TIMEOUT_MS=30000

# Teacher-training advice (default 25s). Observed p50 was 13.7s. Same
# knob governs the sidecar HTTP client TIMEOUT_MS (default 20s).
TEACHER_TRAINING_TIMEOUT_MS=25000

# Quiz generator — split because the sidecar HTTP call and the Genkit
# fallback have different cost profiles (3 parallel variants + multimodal).
# Observed p50 was 32.5s; p75 was failing at the old 45s budget.
QUIZ_CLIENT_TIMEOUT_MS=60000
QUIZ_FALLBACK_TIMEOUT_MS=60000

# Video storyteller — split because RSS + YouTube fetch + LLM categorisation
# tail differs between the two paths. Observed p50 was 12.6s; p75 was
# failing at the old 15s budget.
VIDEO_STORYTELLER_CLIENT_TIMEOUT_MS=30000
VIDEO_STORYTELLER_FALLBACK_TIMEOUT_MS=30000

# Instant answer (default 20s for both client + fallback). Observed p50
# was 8.3s. The client used to race the dispatcher fallback (10s vs 20s)
# — same env var now governs both knobs to keep them aligned.
INSTANT_ANSWER_CLIENT_TIMEOUT_MS=20000
