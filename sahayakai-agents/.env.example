# Copy to .env.local for local dev.
# Never commit .env.local. Production values live in Secret Manager.

# --- Runtime ---
SAHAYAKAI_AGENTS_ENV=development              # development | staging | production
SAHAYAKAI_AGENTS_PORT=8080
SAHAYAKAI_AGENTS_LOG_LEVEL=INFO

# --- GCP ---
GOOGLE_CLOUD_PROJECT=sahayakai-b4248
GOOGLE_CLOUD_REGION=asia-southeast1

# --- Auth ---
# In production this comes from Cloud Run; locally, point to a dev service-account
# JSON. Never commit the JSON file itself.
# GOOGLE_APPLICATION_CREDENTIALS=/abs/path/to/dev-sa.json

# Allow list of service accounts that may invoke this sidecar.
# Comma-separated SA emails. The Next.js runtime SA MUST be in this list.
SAHAYAKAI_AGENTS_ALLOWED_INVOKERS=sahayakai-hotfix-resilience-runtime@sahayakai-b4248.iam.gserviceaccount.com

# Audience claim Next.js signs into its ID token. Must match exactly.
SAHAYAKAI_AGENTS_AUDIENCE=https://sahayakai-agents-<HASH>-as.a.run.app

# --- AI keys ---
# Comma-separated pool for failover. Loaded from Secret Manager in prod.
GOOGLE_GENAI_API_KEY=
# Separate pool used by shadow-mode traffic ONLY. Never share with live path.
# See ARCHITECTURE.md P0 #2 fix.
GOOGLE_GENAI_SHADOW_API_KEY=

# --- HMAC ---
# Per-environment rotating key. Next.js holds the same value; sidecar verifies.
# See ARCHITECTURE.md P1 #15 fix.
SAHAYAKAI_REQUEST_SIGNING_KEY=dev-only-change-me

# --- Session store ---
SAHAYAKAI_FIRESTORE_DATABASE=(default)
SAHAYAKAI_SESSION_COLLECTION=agent_sessions
SAHAYAKAI_SESSION_TTL_HOURS=24

# --- Resilience ---
# Telephony profile: max total wait across all retry attempts. See resilience.py.
SAHAYAKAI_MAX_TOTAL_BACKOFF_SECONDS=7

# --- Telemetry ---
OTEL_SERVICE_NAME=sahayakai-agents
OTEL_RESOURCE_ATTRIBUTES=service.namespace=sahayakai,deployment.environment=development
