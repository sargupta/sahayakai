# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
coverage.xml
htmlcov/

# Virtualenvs
.venv/
venv/
env/

# Build / dist
build/
# Ignore contents of dist/ (not the dir itself) so we can still track the
# one generated artifact below.
dist/*
# Keep the generated TypeScript types so the Next.js side can consume them
# without running the codegen locally. CI regenerates and diffs this file.
!dist/types.generated.ts
*.egg
.tox/

# OS / editor
.DS_Store
.idea/
.vscode/
*.swp
*.swo

# Local env
.env
.env.local
.env.*.local

# Secrets (never commit)
*.pem
*.key
service-account-*.json

# Lockfiles we don't want in the repo yet (until we pick the package manager in G1)
uv.lock
poetry.lock
